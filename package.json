{
  "name": "evalfp",
  "version": "3.0.0",
  "description": "EvalFP — Cuaderno del Profesor para FP",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebake": "node scripts/run_prebake.js",
    "build:mac": "npm run prebake && electron-builder --mac",
    "build:win": "npm run prebake && electron-builder --win",
    "build:all": "npm run prebake && electron-builder --mac --win",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "build": {
    "appId": "com.evalfp.app",
    "productName": "EvalFP",
    "copyright": "© 2026 EvalFP",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "main/**/*",
      "preload.js",
      "db.js",
      "scripts/run_prebake.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "**/*.py",
          "modules/**/*.py"
        ]
      },
      {
        "from": "requirements.txt",
        "to": "requirements.txt"
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "icon": "assets/icon.icns",
      "entitlementsInherit": "entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "EvalFP ${version}",
      "icon": "assets/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.44.0",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "node-schedule": "^2.1.1",
    "winston": "^3.19.0"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "engines": {
    "node": ">=22.12 <26"
  }
}
